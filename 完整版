<script>
    function goScreen(id) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    function doRegister() {
        let u = document.getElementById('reg-u').value; let p = document.getElementById('reg-p').value;
        if(!u || !p) { alert('請填寫完整！'); return; }
        userDB.push({u:u, p:p}); alert('註冊成功！系統為您切換至登入畫面。'); goScreen('scr-login');
    }
    
    function doLogin() {
        let u = document.getElementById('login-u').value; let p = document.getElementById('login-p').value;
        if(userDB.some(x => x.u===u && x.p===p)) { user = u; goScreen('scr-key'); } 
        else { alert('❌ 帳號或密碼錯誤！'); }
    }

    function verifyKey() {
        let k = document.getElementById('act-key').value;
        if(k) { alert('驗證成功！進入大廳'); goScreen('scr-lobby'); } 
        else { alert('無效啟動碼，不知道要購買的話請點擊下方方案購買！'); }
    }

    function selectPay(btn) {
        document.querySelectorAll('.method-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
    }

    function doPayment() {
        let n = document.getElementById('pay-n').value;
        if(!n) { alert('請輸入真實姓名才能付款！'); return; }
        
        document.getElementById('scr-payment').classList.remove('active');
        document.getElementById('loading-overlay').style.display = 'flex';
        
        setTimeout(() => {
            document.getElementById('loading-overlay').style.display = 'none';
            alert('💰 真實付款成功！購買完後系統已幫你輸入啟動碼並解鎖！');
            goScreen('scr-lobby');
        }, 1500);
    }

    function selectWpn(type) {
        sWpn = type;
        document.querySelectorAll('.weapon-card').forEach(c => c.classList.remove('selected'));
        if(type==='AK47') document.getElementById('w-ak').classList.add('selected');
        if(type==='GATLING') document.getElementById('w-gatling').classList.add('selected');
        if(type==='AWP') document.getElementById('w-sniper').classList.add('selected');
    }

    function goPrepareMap() {
        goScreen('scr-map');
        let aHtml = `<b>我方陣容名單:</b><br>[你] ${user} (隊長)<br>`;
        let eHtml = `<b>敵方陣容名單:</b><br>`;
        for(let i=1; i<=49; i++) aHtml += `AI_隊友_${100+i}<br>`;
        for(let i=1; i<=50; i++) eHtml += `Bot_敵人_${500+i}<br>`;
        document.getElementById('ally-roster').innerHTML = aHtml;
        document.getElementById('enemy-roster').innerHTML = eHtml;
    }

    function selectMap(card) {
        document.querySelectorAll('.map-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
    }

    function launch3DGame(e) {
        if(e.button !== 1) {
            alert('⚠️ 系統提示：請在按鈕上按下「滑鼠中鍵 (滾輪鍵向下壓)」才能開始遊戲！');
            e.preventDefault(); return;
        }
        
        if(sWpn === 'AK47') { pStat.max = 30; pStat.spd = 1.0; pStat.dmg = 34; }
        if(sWpn === 'GATLING') { pStat.max = 100; pStat.spd = 0.6; pStat.dmg = 25; }
        if(sWpn === 'AWP') { pStat.max = 5; pStat.spd = 1.1; pStat.dmg = 100; }
        pData.ammo = pStat.max;
        
        document.getElementById('hud-w-name').innerText = sWpn;
        document.getElementById('hud-ammo').innerText = pData.ammo;
        goScreen('scr-lock');
        
        // 確保 3D 引擎能加載
        if(typeof startEngine === 'function') {
            try { startEngine(); } catch(err) { console.error("3D Engine Init Error:", err); }
        }
    }
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
    // 🚨 終極防卡死：如果瀏覽器不給 Pointer Lock，我們直接強制消除黑幕讓你開槍！
    function forceStart3D() {
        if(renderer && renderer.domElement) {
            try {
                renderer.domElement.requestPointerLock = renderer.domElement.requestPointerLock || renderer.domElement.mozRequestPointerLock || renderer.domElement.webkitRequestPointerLock;
                renderer.domElement.requestPointerLock();
            } catch(err) { console.log(err); }
        }
        // 無論如何，物理消除黑幕
        document.getElementById('scr-lock').classList.remove('active');
        document.getElementById('game-ui').style.display = 'block';
        isActive = true;
        keys = {};
    }

    document.addEventListener('pointerlockchange', function() {
        let isLocked = (document.pointerLockElement === renderer.domElement);
        if(!isLocked && !pData.dead && isActive) {
            isActive = false;
            document.getElementById('game-ui').style.display = 'none';
            document.getElementById('scr-lock').classList.add('active');
        }
    });

    // 🧱 絕對防穿牆 (AABB)
    function hitWall(x, z, r) {
        for(let i=0; i<walls.length; i++) {
            let b = walls[i];
            if(x >= b.minX-r && x <= b.maxX+r && z >= b.minZ-r && z <= b.maxZ+r) return true;
        }
        return false;
    }

    function startEngine() {
        if(engineReady) return; engineReady = true;
        
        scene = new THREE.Scene(); scene.background = new THREE.Color(0x050b14); scene.fog = new THREE.Fog(0x050b14, 50, 300);
        camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
        camera.position.set(0, 2.5, 0);

        renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);
        clock = new THREE.Clock();

        scene.add(new THREE.AmbientLight(0xffffff, 0.4));
        let light = new THREE.DirectionalLight(0x00f2ff, 1.0); light.position.set(100,200,50); scene.add(light);

        // 手持武器模型
        const gGroup = new THREE.Group();
        let cHex = sWpn === 'AK47' ? 0xeab308 : (sWpn === 'GATLING' ? 0xff4757 : 0x00f2ff);
        let m1 = new THREE.Mesh(new THREE.BoxGeometry(0.1,0.15,0.7), new THREE.MeshStandardMaterial({color:cHex})); m1.position.z = -0.2;
        let m2 = new THREE.Mesh(new THREE.CylinderGeometry(0.02,0.02,0.5), new THREE.MeshStandardMaterial({color:0x111})); m2.rotation.x = Math.PI/2; m2.position.set(0,0.05,-0.6);
        gGroup.add(m1, m2); gGroup.position.set(0.35, -0.3, -0.5);
        wMesh = gGroup; camera.add(gGroup); scene.add(camera);

        // 生成不能穿牆的大樓地圖
        for(let x=-3; x<=3; x++) {
            for(let z=-3; z<=3; z++) {
                let floor = new THREE.Mesh(new THREE.BoxGeometry(60, 2, 60), new THREE.MeshStandardMaterial({color: 0x1e293b, roughness:0.8}));
                floor.position.set(x*60, -1, z*60); scene.add(floor);
                
                for(let k=0; k<6; k++) {
                    let h = 20 + Math.random()*40; let bw = 10 + Math.random()*5; let bd = 10 + Math.random()*5;
                    let bld = new THREE.Mesh(new THREE.BoxGeometry(bw, h, bd), new THREE.MeshStandardMaterial({color: 0x0f172a, emissive: 0x00f2ff, emissiveIntensity: 0.1}));
                    let bx = x*60 + (Math.random()-0.5)*40; let bz = z*60 + (Math.random()-0.5)*40;
                    bld.position.set(bx, h/2, bz); scene.add(bld);
                    walls.push({ minX: bx-bw/2, maxX: bx+bw/2, minZ: bz-bd/2, maxZ: bz+bd/2 });
                }
            }
        }

        for(let i=0; i<49; i++) spawnAI(true);
        for(let i=0; i<50; i++) spawnAI(false);

        let yaw = 0, pitch = 0;
        document.addEventListener('mousemove', e => { if(isActive) { yaw -= e.movementX*0.002; pitch -= e.movementY*0.002; pitch = Math.max(-1.4, Math.min(1.4, pitch)); camera.quaternion.setFromEuler(new THREE.Euler(pitch,yaw,0,'YXZ')); } });
        
        // 🖱️ 左鍵攻擊右鍵裝子彈
        window.addEventListener('mousedown', e => { if(isActive && e.button===0) doShoot(); else if(isActive && e.button===2) doReload(); });
        window.addEventListener('keydown', e => keys[e.code]=true); window.addEventListener('keyup', e => keys[e.code]=false);

        renderLoop();
    }

    function spawnAI(isF) {
        let grp = new THREE.Group();
        let b = new THREE.Mesh(new THREE.BoxGeometry(1, 2, 1), new THREE.MeshStandardMaterial({color: isF ? 0x2ecc71 : 0xff4757})); grp.add(b);
        let rx, rz;
        do { rx = (Math.random()-0.5)*200; rz = (Math.random()-0.5)*200; } while(hitWall(rx, rz, 1.0)); // 不生在牆內
        grp.position.set(rx, 1, rz);
        ents.push({ m: grp, isF: isF, hp: 100, spd: 8+Math.random()*6, lst: 0, dir: new THREE.Vector3(Math.random()-0.5,0,Math.random()-0.5).normalize() });
        scene.add(grp);
    }

    function doShoot() {
        if(pStat.rld) return;
        if(pData.ammo <= 0) { document.getElementById('hud-reload').style.visibility="visible"; return; }
        pData.ammo--; document.getElementById('hud-ammo').innerText = pData.ammo;
        wMesh.position.z = -0.4; setTimeout(()=>{ if(!pStat.rld) wMesh.position.z = -0.5; }, 50);
        let b = new THREE.Mesh(new THREE.SphereGeometry(0.2,4,4), new THREE.MeshBasicMaterial({color: 0xeab308}));
        b.position.copy(camera.position); b.velocity = new THREE.Vector3(0,0,-1).applyQuaternion(camera.quaternion).normalize().multiplyScalar(150);
        b.owner = 'player'; b.dmg = pStat.dmg; b.spawn = Date.now(); scene.add(b); bullets.push(b);
    }
    
    function doReload() {
        if(pStat.rld || pData.ammo === pStat.max) return;
        pStat.rld = true; document.getElementById('hud-reload').innerText = "裝彈中..."; document.getElementById('hud-reload').style.visibility="visible";
        wMesh.position.y = -0.6;
        setTimeout(() => { pData.ammo = pStat.max; document.getElementById('hud-ammo').innerText = pData.ammo; document.getElementById('hud-reload').style.visibility="hidden"; pStat.rld=false; wMesh.position.y = -0.3; }, 1500);
    }

    function renderLoop() {
        requestAnimationFrame(renderLoop); let dt = Math.min(clock.getDelta(), 0.1);
        
        if(isActive && !pStat.dead) {
            let speed = (keys['ShiftLeft'] ? 25 : 12) * pStat.spd;
            let move = new THREE.Vector3(0,0,0);
            let fwd = new THREE.Vector3(0,0,-1).applyQuaternion(camera.quaternion); fwd.y=0; fwd.normalize();
            let right = new THREE.Vector3().crossVectors(fwd, new THREE.Vector3(0,1,0)).normalize();
            
            // 可以移動
            if(keys['KeyW']) move.add(fwd); if(keys['KeyS']) move.add(fwd.clone().negate());
            if(keys['KeyA']) move.add(right.clone().negate()); if(keys['KeyD']) move.add(right);
            
            if(move.lengthSq() > 0) {
                let dMove = move.normalize().multiplyScalar(speed * dt);
                let nx = camera.position.x + dMove.x; let nextZ = camera.position.z + dMove.z;
                // 🛑 不能穿牆
                if(!hitWall(nx, camera.position.z, 0.5)) camera.position.x = nx;
                if(!hitWall(camera.position.x, nextZ, 0.5)) camera.position.z = nextZ;
                if(!pStat.rld) wMesh.position.y = -0.3 + Math.sin(Date.now()*0.01)*0.02;
            }
        }

        let fC = !pStat.dead?1:0, eC = 0;
        let rHud = document.getElementById('radar'); rHud.innerHTML = "";

        // 🤖 隊友和敵人要有聰明的頭腦，不能穿牆
        ents.forEach(en => {
            if(en.isF) fC++; else eC++;
            
            let dx = en.m.position.x - camera.position.x; let dz = en.m.position.z - camera.position.z;
            if(dx*dx + dz*dz < 8000) {
                let dot = document.createElement('div'); dot.className = "radar-dot"; dot.style.background = en.isF ? '#2ecc71':'#ff4757';
                dot.style.left = (50 + dx*0.5) + '%'; dot.style.top = (50 + dz*0.5) + '%'; rHud.appendChild(dot);
            }

            let tgt = null; let minD = 150;
            if(!en.isF && !pStat.dead) { tgt = camera.position; minD = en.m.position.distanceTo(camera.position); }
            ents.forEach(other => { if(en.isF !== other.isF) { let d = en.m.position.distanceTo(other.m.position); if(d < minD) { minD = d; tgt = other.m.position; } } });

            if(tgt) {
                en.m.lookAt(tgt.x, 1, tgt.z);
                let tDir = new THREE.Vector3().subVectors(tgt, en.m.position).normalize();
                let nx = en.m.position.x + tDir.x * en.spd * dt; let nz = en.m.position.z + tDir.z * en.spd * dt;
                
                // 🤖 聰明繞道 (不能穿牆)
                if(minD > 15) {
                    let hx = hitWall(nx, en.m.position.z, 0.8); let hz = hitWall(en.m.position.x, nz, 0.8);
                    if(!hx) en.m.position.x = nx; else en.m.position.z += (Math.random()>0.5?1:-1)*en.spd*dt; 
                    if(!hz) en.m.position.z = nz; else en.m.position.x += (Math.random()>0.5?1:-1)*en.spd*dt;
                }
                if(minD < 60 && Date.now() - en.lst > 2000) { 
                    let b = new THREE.Mesh(new THREE.SphereGeometry(0.2,4,4), new THREE.MeshBasicMaterial({color: 0xeab308}));
                    b.position.copy(en.m.position); b.velocity = tDir.normalize().multiplyScalar(150); b.owner = en; b.dmg = 20; b.spawn = Date.now();
                    scene.add(b); bullets.push(b); en.lst = Date.now(); 
                }
            } else {
                if(Math.random()<0.02) en.dir.set(Math.random()-0.5, 0, Math.random()-0.5).normalize();
                let nx = en.m.position.x + en.dir.x * en.spd * dt; let nz = en.m.position.z + en.dir.z * en.spd * dt;
                if(!hitWall(nx, en.m.position.z, 0.8)) en.m.position.x = nx; else en.dir.x *= -1;
                if(!hitWall(en.m.position.x, nz, 0.8)) en.m.position.z = nz; else en.dir.z *= -1;
                en.m.lookAt(en.m.position.clone().add(en.dir));
            }
        });

        document.getElementById('f-count').innerText = fC; document.getElementById('e-count').innerText = eC;
        if(eC <= 0 && ents.length > 0 && isActive) { isActive=false; document.exitPointerLock(); goScreen('scr-result'); document.getElementById('result-title').innerText="🏆 勝利！"; document.getElementById('result-title').style.color="#eab308"; document.getElementById('game-ui').style.display='none'; }
        if(fC <= 0 && isActive) { isActive=false; document.exitPointerLock(); goScreen('scr-result'); document.getElementById('result-title').innerText="💀 戰敗！"; document.getElementById('result-title').style.color="#ff4757"; document.getElementById('game-ui').style.display='none'; }

        for(let i=bullets.length-1; i>=0; i--) {
            let b = bullets[i]; b.position.add(b.velocity.clone().multiplyScalar(dt));
            if(Date.now() - b.spawn > 2000 || hitWall(b.position.x, b.position.z, 0.2)) { scene.remove(b); bullets.splice(i,1); continue; } 
            
            let hit = false;
            for(let j=ents.length-1; j>=0; j--) {
                let en = ents[j]; if(b.owner !== en && b.position.distanceTo(en.m.position) < 1.5) {
                    en.hp -= b.dmg; if(en.hp <= 0) { scene.remove(en.m); ents.splice(j,1); }
                    scene.remove(b); bullets.splice(i,1); hit = true; break;
                }
            }
            if(hit) continue;
            if(b.owner !== 'player' && !pStat.dead && b.position.distanceTo(camera.position) < 1.5) {
                scene.remove(b); bullets.splice(i,1);
                pData.hp -= b.dmg; if(pData.hp<0) pData.hp=0;
                document.getElementById('hp-val').innerText = pData.hp; document.getElementById('hp-fill').style.width = pData.hp+"%";
                if(pData.hp<=30) document.getElementById('hp-fill').style.background = "#ff4757";
                if(pData.hp<=0) { pStat.dead = true; camera.remove(wMesh); isActive=false; document.exitPointerLock(); goScreen('scr-result'); document.getElementById('result-title').innerText="💀 戰敗！"; document.getElementById('result-title').style.color="#ff4757"; document.getElementById('game-ui').style.display='none'; }
            }
        }
        if(renderer && isActive) renderer.render(scene, camera);
    }
</script>
</body>
</html>
