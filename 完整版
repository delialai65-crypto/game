<!DOCTYPE html>
<html lang="zh-TW">
<head>
    <meta charset="UTF-8">
    <title>Delta Cube: Battlezone Absolute Order v13.0</title>
    <style>
        body, html { margin: 0; padding: 0; width: 100%; height: 100%; overflow: hidden; background: #050b14; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; color: #fff; user-select: none; }
        canvas { display: block; position: fixed; top: 0; left: 0; z-index: 1; outline: none; }

        /* 🛡️ 絕對控光層：沒啟動的畫面「物理上不存在」，100% 根除點擊無效 Bug */
        .screen { display: none; position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: radial-gradient(circle at center, #16223f 0%, #070c1b 100%); z-index: 1000; overflow-y: auto; flex-direction: column; align-items: center; justify-content: flex-start; padding: 30px 10px; box-sizing: border-box; }
        .screen.active { display: flex; }
        .screen-center { justify-content: center; }

        /* 💎 發光科技面板 */
        .auth-box { background: rgba(15, 23, 42, 0.85); padding: 40px 30px; border-radius: 20px; border: 2px solid #00f2ff; width: 400px; text-align: center; box-shadow: 0 0 30px rgba(0, 242, 255, 0.3); backdrop-filter: blur(10px); }
        .auth-box h2 { font-size: 28px; color: #00f2ff; letter-spacing: 2px; margin-top: 0; margin-bottom: 20px; text-shadow: 0 0 10px rgba(0,242,255,0.5); }
        
        input, select { width: 100%; padding: 14px; margin: 8px 0 16px 0; background: #0c1324; color: #fff; border: 1px solid #1e3a5f; border-radius: 8px; box-sizing: border-box; font-size: 14px; transition: 0.2s; outline: none; }
        input:focus { border-color: #00f2ff; box-shadow: 0 0 10px rgba(0,242,255,0.4); }
        
        .btn { width: 100%; padding: 14px 20px; cursor: pointer; border: none; font-weight: bold; border-radius: 8px; font-size: 15px; transition: 0.2s; letter-spacing: 1px; box-sizing: border-box; text-align:center; }
        .btn-cyan { background: #00f2ff; color: #000; box-shadow: 0 0 15px rgba(0,242,255,0.4); } .btn-cyan:hover { background: #38bdf8; box-shadow: 0 0 25px #00f2ff; transform: translateY(-2px); }
        .btn-gold { background: #eab308; color: #000; box-shadow: 0 0 15px rgba(234,179,8,0.4); } .btn-gold:hover { background: #facc15; box-shadow: 0 0 25px #eab308; transform: translateY(-2px); }
        .btn-green { background: #10b981; color: #fff; box-shadow: 0 0 10px rgba(16,185,129,0.3); } .btn-green:hover { background: #059669; }
        .auth-switch { font-size: 13px; color: #38bdf8; cursor: pointer; text-decoration: underline; margin-top: 15px; display: inline-block; }

        /* 10 種方案畫面牆 */
        .plan-grid { display: grid; grid-template-columns: repeat(5, 1fr); gap: 15px; width: 100%; max-width: 1200px; margin: 20px auto; }
        .plan-card { background: #131f3b; border: 2px solid #1e3564; padding: 20px 10px; border-radius: 12px; text-align: center; cursor: pointer; transition: 0.3s; }
        .plan-card:hover { border-color: #00f2ff; box-shadow: 0 0 20px rgba(0,242,255,0.3); transform: translateY(-5px); background: rgba(0,242,255,0.1); }
        .plan-card.gold { border-color: #eab308; } .plan-card.gold:hover { border-color: #facc15; box-shadow: 0 0 20px rgba(234,179,8,0.3); background: rgba(234,179,8,0.1); }
        .plan-card.legend { border-color: #ff4757; } .plan-card.legend:hover { border-color: #ff6b81; box-shadow: 0 0 20px rgba(255,71,87,0.3); background: rgba(255,71,87,0.1); }
        .plan-price { font-size: 26px; font-weight: bold; color: #fff; margin: 15px 0; }
        .plan-features { font-size: 12px; color: #94a3b8; list-style: none; padding: 0; text-align: left; line-height: 1.8; margin-bottom: 20px; }

        /* 付款資料模組 */
        .payment-container { background: #0b1120; border: 1px solid #38bdf8; padding: 30px; border-radius: 16px; width: 850px; display: flex; gap: 20px; margin: auto; box-shadow: 0 0 40px rgba(0,0,0,0.8); }
        .pay-col { flex: 1; background: rgba(0,0,0,0.3); padding: 20px; border-radius: 10px; border: 1px solid #1e3a8a; }
        .method-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 8px; margin-bottom: 15px; }
        .method-btn { background: #1e293b; color: #cbd5e1; border: 1px solid #334155; padding: 12px; border-radius: 6px; cursor: pointer; font-size: 12px; text-align: center; }
        .method-btn.selected { background: rgba(16, 185, 129, 0.2); border-color: #10b981; color: #10b981; font-weight: bold; }
        #loading-overlay { display: none; position: fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.9); z-index:9999; flex-direction:column; align-items:center; justify-content:center; color:#00f2ff; font-size:24px; font-weight:bold; letter-spacing:2px; }

        /* 控制大廳 */
        .lobby-grid { display: grid; grid-template-columns: 280px 1fr 300px; gap: 15px; width: 100%; max-width: 1280px; margin: auto; }
        .lobby-panel { background: rgba(13, 23, 49, 0.85); border: 1px solid #1d3557; border-radius: 12px; padding: 15px; display: flex; flex-direction: column; height: 500px; }
        .panel-title { color: #00f2ff; font-weight: bold; font-size: 15px; border-bottom: 1px solid rgba(0,242,255,0.3); padding-bottom: 8px; margin-bottom: 10px; }
        .event-list { flex: 1; overflow-y: auto; padding-right: 5px; }
        .event-item { padding: 10px; background: rgba(0,0,0,0.4); border: 1px solid #1e293b; margin-bottom: 6px; border-radius: 6px; font-size: 12px; cursor: pointer; }
        .event-item.active { border-color: #00f2ff; background: rgba(0,242,255,0.15); box-shadow: 0 0 10px rgba(0,242,255,0.2); font-weight:bold; }
        
        .checkin-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 6px; margin-bottom: 15px; }
        .checkin-box { background: #050b14; border: 1px solid #1e293b; padding: 10px 4px; text-align: center; border-radius: 6px; font-size: 11px; cursor: pointer; }
        .checkin-box.done { border-color: #10b981; color: #10b981; background: rgba(16,185,129,0.1); }
        
        .shop-row { display: flex; justify-content: space-between; align-items: center; background: #050b14; padding: 10px; border-radius: 6px; margin-bottom: 8px; border: 1px solid #1e293b; font-size: 12px; }
        .shop-buy-btn { background: #eab308; border:none; border-radius:4px; font-size:11px; font-weight:bold; padding:4px 8px; cursor:pointer; color:#000; }
        .task-box { background: #050b14; padding: 12px; border-radius: 6px; border: 1px solid #1e293b; margin-bottom: 10px; font-size: 12px;}
        .bar-bg { height: 6px; background: #1e293b; border-radius: 3px; margin-top: 8px; overflow: hidden; }
        .bar-fill { height: 100%; background: #38bdf8; width: 100%; }

        /* 整備室 & 地圖選擇 */
        .weapon-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; max-width: 800px; margin: 30px auto; }
        .weapon-card { background: #0b1120; border: 2px solid #1e3a8a; padding: 30px 15px; text-align: center; border-radius: 12px; cursor: pointer; transition: 0.3s; }
        .weapon-card.selected { border-color: #eab308; background: rgba(234,179,8,0.15); box-shadow: 0 0 20px rgba(234,179,8,0.3); transform: scale(1.05); }
        
        .map-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 10px; width: 100%; max-width: 950px; margin: 20px auto; max-height: 250px; overflow-y: auto; padding-right: 10px; }
        .map-card { background: #0b1120; border: 1px solid #1e3a8a; padding: 15px; text-align: center; border-radius: 8px; font-size: 13px; cursor: pointer; transition: 0.2s; }
        .map-card.selected { border-color: #10b981; background: rgba(16,185,129,0.2); box-shadow: 0 0 15px rgba(16,185,129,0.3); font-weight: bold; }
        
        .roster-area { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; width: 100%; max-width: 950px; margin-top: 15px; }
        .roster-box { background: rgba(0,0,0,0.6); border: 1px solid #1e3a8a; height: 160px; border-radius: 8px; padding: 15px; overflow-y: auto; font-size: 13px; line-height: 1.8; }

        /* 3D 遊戲啟動層 (保證點擊能鎖定) */
        #scr-lock { position: fixed; top:0; left:0; width:100%; height:100%; display: none; z-index: 9999; flex-direction:column; align-items:center; justify-content:center; background:rgba(0,0,0,0.95); cursor:pointer; }
        #scr-lock.active { display: flex; }

        /* 戰場 HUD */
        #game-ui { position: fixed; top: 0; left: 0; width: 100%; height: 100%; pointer-events: none; display: none; z-index: 100; }
        .hud-nav { padding: 15px 25px; display: flex; justify-content: space-between; align-items: center; background: rgba(15,23,42,0.8); border-bottom: 1px solid #1e3a8a; font-weight: bold; font-size: 14px; }
        .hp-container { display: flex; align-items: center; gap: 10px; background: rgba(0,0,0,0.5); padding: 8px 15px; border-radius: 20px; border: 1px solid rgba(255,255,255,0.1); }
        .hp-bar { width: 150px; height: 12px; background: #1e293b; border-radius: 6px; overflow: hidden; }
        .hp-fill { height: 100%; background: #2ecc71; width: 100%; box-shadow: 0 0 10px #2ecc71; transition: 0.2s; }
        .weapon-hud { position: absolute; bottom: 30px; left: 30px; background: rgba(15,23,42,0.9); padding: 20px; border-radius: 12px; border-left: 5px solid #eab308; }
        .radar-hud { position: absolute; bottom: 30px; right: 30px; width: 180px; height: 180px; background: rgba(0,0,0,0.8); border-radius: 50%; border: 2px solid #00f2ff; overflow: hidden; }
        .radar-dot { position: absolute; width: 6px; height: 6px; border-radius: 50%; transform: translate(-50%, -50%); }

        @keyframes spin { 100% { transform: rotate(360deg); } }
    </style>
</head>
