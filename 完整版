<script>
    // 全域變數初始化
    var userDB = [{u: 'admin', p: 'password123'}];
    var cUser = 'admin';
    var sWpn = 'AK47';
    var pData = { hp: 100, ammo: 30, maxAmmo: 30, spd: 1.0, dmg: 34, reload: false, dead: false };

    // 核心切換引擎 (物理隱藏)
    function goScreen(id) {
        document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
        document.getElementById(id).classList.add('active');
    }

    // 帳號邏輯
    function doRegister() {
        let u = document.getElementById('reg-u').value.trim(); let p = document.getElementById('reg-p').value.trim();
        if(!u || !p) { alert('請填寫完整帳號密碼！'); return; }
        userDB.push({u:u, p:p}); alert('註冊成功！系統已為您切換至登入畫面。'); goScreen('scr-login');
    }
    
    function doLogin() {
        let u = document.getElementById('login-u').value.trim(); let p = document.getElementById('login-p').value.trim();
        if(userDB.some(x => x.u===u && x.p===p)) { cUser = u; goScreen('scr-key'); } 
        else { alert('❌ 指揮官，帳號或密碼發生安全驗證錯誤！'); }
    }

    function verifyKey() {
        let k = document.getElementById('act-key').value.trim();
        if(k) { alert('終端金鑰驗證成功！正在啟動控制大廳'); goScreen('scr-lobby'); } 
        else { alert('無效的啟動碼！指揮官，您需要購買授權才能放行。'); }
    }

    function selectPay(btn) {
        document.querySelectorAll('.method-btn').forEach(b => b.classList.remove('selected'));
        btn.classList.add('selected');
    }

    // 付款載入
    function doPayment() {
        let n = document.getElementById('pay-n').value;
        if(!n) { alert('請填寫真實姓名完成金流認證！'); return; }
        goScreen('empty'); // 先隱藏目前畫面
        let loader = document.getElementById('loading-overlay');
        loader.style.display = 'flex';
        setTimeout(() => {
            loader.style.display = 'none';
            alert('💰 真實金流授權成功！系統已自動為您代填啟動碼金鑰。');
            goScreen('scr-lobby');
        }, 1500);
    }

    function switchWeaponScreen() {
        goScreen('scr-weapon');
    }

    function doSelectWeapon(type) {
        sWpn = type;
        document.querySelectorAll('.weapon-card').forEach(c => c.classList.remove('selected'));
        if(type==='AK47') document.getElementById('w-ak').classList.add('selected');
        if(type==='GATLING') document.getElementById('w-gatling').classList.add('selected');
        if(type==='AWP') document.getElementById('w-sniper').classList.add('selected');
    }

    function goPrepareMap() {
        goScreen('scr-map');
        // 名單載入
        let a = `<b>我方陣容名單:</b><br>[你] ${cUser} (隊長)<br>`;
        let e = `<b>敵方陣容名單:</b><br>`;
        for(let i=1; i<=49; i++) a += `AI_友軍_${100+i}<br>`;
        for(let i=1; i<=50; i++) e += `Bot_敵人_${500+i}<br>`;
        document.getElementById('ally-roster').innerHTML = a;
        document.getElementById('enemy-roster').innerHTML = e;
    }

    function doSelectMap(card) {
        document.querySelectorAll('.map-card').forEach(c => c.classList.remove('selected'));
        card.classList.add('selected');
    }

    // 滑鼠中鍵開戰核心
    function launch3DGame(e) {
        // e.button === 1 代表滑鼠中鍵 (滾輪鍵向下壓)
        if(e.button !== 1) {
            alert("⚠️ 指揮官戰術情報：請在黃色按鈕上按下「滑鼠中鍵 (滾輪鍵向下壓)」才能正式開戰！");
            e.preventDefault(); return;
        }
        
        // 槍枝數值配置
        if(sWpn === 'AK47') { pData.maxAmmo = 30; pData.spd = 1.0; pData.dmg = 34; }
        if(sWpn === 'GATLING') { pData.maxAmmo = 100; pData.spd = 0.6; pData.dmg = 25; }
        if(sWpn === 'AWP') { pData.maxAmmo = 5; pData.spd = 1.1; pData.dmg = 100; }
        pData.ammo = pData.maxAmmo;
        
        // HUD 初始化
        document.getElementById('hud-w-name').innerText = sWpn;
        document.getElementById('hud-ammo').innerText = pData.ammo;
        document.getElementById('scr-lock').classList.add('active'); // 顯示鎖定畫面
        
        // 延遲啟動，確保畫面準備好
        setTimeout(init3DEngine, 100);
    }

    // 決策視窗邏輯
    document.getElementById('btn-to-lobby').onclick = function() {
        if(renderer) { document.body.removeChild(renderer.domElement); renderer.dispose(); renderer=null; }
        location.reload(); // 最徹底的重置
    };
    
    document.getElementById('btn-play-again').onclick = function() {
        document.getElementById('scr-result').classList.remove('active');
        if(renderer) { document.body.removeChild(renderer.domElement); renderer.dispose(); renderer=null; }
        engineReady = false; ents = []; bullets = []; walls = [];
        // 跳過中鍵開戰，直接進入開戰鎖定
        document.getElementById('scr-lock').classList.add('active');
        pData.hp = 100; pData.ammo = pData.maxAmmo; pData.dead = false; pData.reload = false;
        document.getElementById('hp-val').innerText = '100';
        document.getElementById('hp-fill').style.width = '100%';
        document.getElementById('hp-fill').style.background = '#2ecc71';
        document.getElementById('hud-ammo').innerText = pData.ammo;
        setTimeout(init3DEngine, 100);
    };
</script>

<script src="https://cdnjs.cloudflare.com/ajax/libs/three.js/r128/three.min.js"></script>
<script>
    var scene, camera, renderer, clock, isActive = false;
    var keys = {}, ents = [], bullets = [], walls = [];
    var wMesh = null, engineReady = false;

    // 滑鼠鎖定邏輯
    function lockPointer() { if(renderer) renderer.domElement.requestPointerLock(); }
    document.addEventListener('pointerlockchange', () => {
        isActive = (document.pointerLockElement === renderer.domElement);
        if(isActive) {
            document.getElementById('scr-lock').classList.remove('active');
            document.getElementById('game-ui').style.display = 'block';
            keys = {}; // 防止移動鬼畜
        } else if(!pData.dead) {
            document.getElementById('game-ui').style.display = 'none';
            document.getElementById('scr-lock').classList.add('active');
        }
    });

    // 不能穿牆的碰撞檢測 (AABB)
    function checkAABB(x, z, radius) {
        for(let i=0; i<walls.length; i++) {
            let b = walls[i];
            if(x >= b.minX-radius && x <= b.maxX+radius && z >= b.minZ-radius && z <= b.maxZ+r) return true;
        }
        return false;
    }

    // 核心引擎初始化
    function init3DEngine() {
        if(engineReady) return; engineReady = true;
        
        scene = new THREE.Scene(); scene.background = new THREE.Color(0x050b14); scene.fog = new THREE.Fog(0x050b14, 50, 300);
        camera = new THREE.PerspectiveCamera(75, window.innerWidth/window.innerHeight, 0.1, 1000);
        camera.position.set(0, 2.5, 0); // 眼睛高度

        renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);
        clock = new THREE.Clock();

        scene.add(new THREE.AmbientLight(0xffffff, 0.4));
        let light = new THREE.DirectionalLight(0x00f2ff, 1.0); light.position.set(100,200,50); scene.add(light);

        // 手持武器模型
        const gGroup = new THREE.Group();
        let cHex = sWpn === 'AK47' ? 0xeab308 : (sWpn === 'GATLING' ? 0xff4757 : 0x00f2ff);
        let m1 = new THREE.Mesh(new THREE.BoxGeometry(0.1,0.15,0.7), new THREE.MeshStandardMaterial({color:cHex, metalness:0.8, roughness:0.2})); m1.position.z = -0.2;
        let m2 = new THREE.Mesh(new THREE.CylinderGeometry(0.02,0.02,0.5), new THREE.MeshStandardMaterial({color:0x111})); m2.rotation.x = Math.PI/2; m2.position.set(0,0.05,-0.6);
        gGroup.add(m1, m2); gGroup.position.set(0.35, -0.3, -0.5);
        wMesh = gGroup; camera.add(gGroup); scene.add(camera);

        // 生成不能穿牆的地圖大樓
        for(let x=-3; x<=3; x++) {
            for(let z=-3; z<=3; z++) {
                let floor = new THREE.Mesh(new THREE.BoxGeometry(60, 2, 60), new THREE.MeshStandardMaterial({color: 0x1e293b, roughness:0.8}));
                floor.position.set(x*60, -1, z*60); scene.add(floor);
                
                // 大樓 (物理硬體層，不能穿牆)
                for(let k=0; k<6; k++) {
                    let h = 20 + Math.random()*40; let bw = 10 + Math.random()*5; let bd = 10 + Math.random()*5;
                    let bld = new THREE.Mesh(new THREE.BoxGeometry(bw, h, bd), new THREE.MeshStandardMaterial({color: 0x0f172a, emissive: 0x00f2ff, emissiveIntensity: 0.1, roughness:0.6}));
                    let bx = x*60 + (Math.random()-0.5)*40; let bz = z*60 + (Math.random()-0.5)*40;
                    bld.position.set(bx, h/2, bz); scene.add(bld);
                    
                    // 寫入不能穿牆的數據庫
                    walls.push({ minX: bx-bw/2, maxX: bx+bw/2, minZ: bz-bd/2, maxZ: bz+bd/2 });
                }
            }
        }

        // 生成 AI 隊友和敵人 (頭上顯示血量核心)
        for(let i=0; i<49; i++) spawnAIEntity(true);  // 我方隊友
        for(let i=0; i<50; i++) spawnAIEntity(false); // 敵方

        // 核心遊玩操作升級
        let yaw = 0, pitch = 0;
        document.addEventListener('mousemove', e => { if(isActive) { yaw -= e.movementX*0.002; pitch -= e.movementY*0.002; pitch = Math.max(-1.4, Math.min(1.4, pitch)); camera.quaternion.setFromEuler(new THREE.Euler(pitch,yaw,0,'YXZ')); } });
        
        // 移動控制與防穿牆核心
        window.addEventListener('keydown', e => keys[e.code]=true); 
        window.addEventListener('keyup', e => keys[e.code]=false);

        // 攻擊與裝彈
        window.addEventListener('mousedown', e => { if(isActive && e.button===0) playerShoot(); else if(isActive && e.button===2) playerReload(); });

        mainRenderLoop();
    }

    // 生成頭上顯示血量的 AI 實體
    function spawnAIEntity(isF) {
        let group = new THREE.Group();
        // 聰明的頭腦身體
        let body = new THREE.Mesh(new THREE.BoxGeometry(1, 2, 1), new THREE.MeshStandardMaterial({color: isF ? 0x2ecc71 : 0xff4757, metalness:0.3, roughness:0.7})); group.add(body);
        
        // 抬頭血量條顯示裝置器 (Billboard)
        const canvas = document.createElement('canvas'); canvas.width = 128; canvas.height = 32;
        const ctx = canvas.getContext('2d');
        const texture = new THREE.CanvasTexture(canvas);
        const spriteMat = new THREE.SpriteMaterial({ map: texture });
        const sprite = new THREE.Sprite(spriteMat);
        sprite.scale.set(3, 0.75, 1);
        sprite.position.set(0, 2.5, 0); // 在身體上方
        group.add(sprite);

        // 尋找不能穿牆的出生點
        let rx, rz;
        do { rx = (Math.random()-0.5)*220; rz = (Math.random()-0.5)*220; } while(checkAABB(rx, rz, 1.0)); // 避免生在牆內
        group.position.set(rx, 1, rz);
        
        ents.push({ 
            m: group, isF: isF, hp: 100, spd: 8+Math.random()*6, lastS: 0, 
            hbCtx: ctx, hbTex: texture, hbColor: isF ? '#2ecc71':'#ff4757',
            dir: new THREE.Vector3(Math.random()-0.5,0,Math.random()-0.5).normalize() 
        });
        scene.add(group);
    }

    // 更新抬頭血量條
    function updateAIHealthBar(en) {
        en.hbCtx.clearRect(0,0,128,32);
        // 背景
        en.hbCtx.fillStyle = '#111'; en.hbCtx.fillRect(0,0,128,32); en.hbCtx.strokeStyle = '#fff'; en.hbCtx.strokeRect(0,0,128,32);
        // 血量條 (動態顏色變換)
        let fillPct = en.hp/100;
        let c = en.hbColor; if(fillPct < 0.5) c = '#eab308'; if(fillPct < 0.25) c = '#ff4757';
        en.hbCtx.fillStyle = c; en.hbCtx.fillRect(4,4, (128-8)*fillPct, 32-8);
        en.hbTex.needsUpdate = true;
    }

    // 玩家攻擊
    function playerShoot() {
        if(pData.reload) return;
        if(pData.ammo <= 0) { document.getElementById('hud-reload').style.visibility="visible"; return; }
        pData.ammo--; document.getElementById('hud-ammo').innerText = pData.ammo;
        wMesh.position.z = -0.4; setTimeout(()=>{ if(!pData.reload) wMesh.position.z = -0.5; }, 50); // 聰明換彈動作
        
        let b = new THREE.Mesh(new THREE.SphereGeometry(0.2,4,4), new THREE.MeshBasicMaterial({color: 0xeab308}));
        b.position.copy(camera.position); b.velocity = new THREE.Vector3(0,0,-1).applyQuaternion(camera.quaternion).normalize().multiplyScalar(150);
        b.owner = 'player'; b.dmg = pData.dmg; b.spawn = Date.now(); scene.add(b); bullets.push(b);
    }
    
    // 玩家裝彈
    function playerReload() {
        if(pData.reload || pData.ammo === pData.maxAmmo) return;
        pData.reload = true; document.getElementById('hud-reload').innerText = "裝彈中..."; document.getElementById('hud-reload').style.visibility="visible";
        wMesh.position.y = -0.6;
        setTimeout(() => { pData.ammo = pData.maxAmmo; document.getElementById('hud-ammo').innerText = pData.ammo; document.getElementById('hud-reload').style.visibility="hidden"; pData.reload=false; wMesh.position.y = -0.3; }, 1500);
    }

    // 硬體級硬核移動 & AI 抬頭血量條智慧型主迴圈
    function mainRenderLoop() {
        requestAnimationFrame(mainRenderLoop); let dt = Math.min(clock.getDelta(), 0.1);
        
        // 核心遊玩操作：硬核物理移動 & 防穿牆
        if(isActive && !pData.dead) {
            let speed = (keys['ShiftLeft'] ? 25 : 12) * pData.spd;
            let move = new THREE.Vector3(0,0,0);
            let fwd = new THREE.Vector3(0,0,-1).applyQuaternion(camera.quaternion); fwd.y=0; fwd.normalize();
            let right = new THREE.Vector3().crossVectors(fwd, new THREE.Vector3(0,1,0)).normalize();
            if(keys['KeyW']) move.add(fwd); if(keys['KeyS']) move.add(fwd.clone().negate());
            if(keys['KeyA']) move.add(right.clone().negate()); if(keys['KeyD']) move.add(right);
            
            if(move.lengthSq() > 0) {
                let dMove = move.normalize().multiplyScalar(speed * dt);
                let nx = camera.position.x + dMove.x; let nextZ = camera.position.z + dMove.z;
                // 🛑 不能穿牆硬體層
                if(!checkAABB(nx, camera.position.z, 0.5)) camera.position.x = nx;
                if(!checkAABB(camera.position.x, nextZ, 0.5)) camera.position.z = nextZ;
                if(!pData.reload) wMesh.position.y = -0.3 + Math.sin(Date.now()*0.01)*0.02; // 移動呼吸感
            }
        }

        // AI 智慧防穿牆、聰明的頭腦尋路與血量條更新
        let fCount = !pData.dead?1:0, eCount = 0;
        let rHud = document.getElementById('radar'); rHud.innerHTML = "";

        ents.forEach(en => {
            if(en.isF) fCount++; else eCount++;
            updateAIHealthBar(en); // 每幀更新頭上血量條

            // 雷達發光掃描
            let dx = en.m.position.x - camera.position.x; let dz = en.m.position.z - camera.position.z;
            if(dx*dx + dz*dz < 8000) {
                let dot = document.createElement('div'); dot.className = "radar-dot"; dot.style.background = en.hbColor;
                dot.style.left = (50 + dx*0.5) + '%'; dot.style.top = (50 + dz*0.5) + '%'; rHud.appendChild(dot);
            }

            // 聰明的頭腦尋路 & 防穿牆
            let tgt = null; let minD = 180;
            if(!en.isF && !pData.dead) { tgt = camera.position; minD = en.m.position.distanceTo(camera.position); }
            ents.forEach(other => { if(en.isF !== other.isF) { let d = en.m.position.distanceTo(other.m.position); if(d < minD) { minD = d; tgt = other.m.position; } } });

            if(tgt) {
                en.m.lookAt(tgt.x, 1, tgt.z);
                let tDir = new THREE.Vector3().subVectors(tgt, en.m.position).normalize();
                let nx = en.m.position.x + tDir.x * en.spd * dt; let nextZ = en.m.position.z + tDir.z * en.spd * dt;
                
                // 🤖 聰明繞道 (不能穿牆)
                if(minD > 15) {
                    let hx = checkAABB(nx, en.m.position.z, 0.8); let hz = checkAABB(en.m.position.x, nextZ, 0.8);
                    if(!hx) en.m.position.x = nx; else en.m.position.z += (Math.random()>0.5?1:-1)*en.spd*dt; // 撞牆側滑
                    if(!hz) en.m.position.z = nextZ; else en.m.position.x += (Math.random()>0.5?1:-1)*en.spd*dt;
                }
                if(minD < 70 && Date.now() - en.lastS > 2000) { 
                    let b = new THREE.Mesh(new THREE.SphereGeometry(0.2,4,4), new THREE.MeshBasicMaterial({color: 0xeab308}));
                    b.position.copy(en.m.position); b.velocity = tDir.normalize().multiplyScalar(150); b.owner = en; b.dmg = 20; b.spawn = Date.now();
                    scene.add(b); bullets.push(b); en.lastS = Date.now(); 
                }
            } else {
                // 自由不能穿牆巡邏
                if(Math.random()<0.02) en.dir.set(Math.random()-0.5, 0, Math.random()-0.5).normalize();
                let nx = en.m.position.x + en.dir.x * en.spd * dt; let nextZ = en.m.position.z + en.dir.z * en.spd * dt;
                if(!checkAABB(nx, en.m.position.z, 0.8)) en.m.position.x = nx; else en.dir.x *= -1;
                if(!checkAABB(en.m.position.x, nextZ, 0.8)) en.m.position.z = nextZ; else en.dir.z *= -1;
                en.m.lookAt(en.m.position.clone().add(en.dir));
            }
        });

        // 結束條件
        document.getElementById('f-count').innerText = fCount; document.getElementById('e-count').innerText = eCount;
        if(eCount <= 0 && ents.length > 0 && isActive) triggerEndModal(true); if(fCount <= 0 && isActive) triggerEndModal(false);

        // 子彈物理與防穿牆打大樓
        for(let i=bullets.length-1; i>=0; i--) {
            let b = bullets[i]; b.position.add(b.velocity.clone().multiplyScalar(dt));
            if(Date.now() - b.spawn > 2000 || checkAABB(b.position.x, b.position.z, 0.2)) { scene.remove(b); bullets.splice(i,1); continue; } 
            
            let hit = false;
            for(let j=ents.length-1; j>=0; j--) {
                let en = ents[j]; if(b.owner !== en && b.position.distanceTo(en.m.position) < 1.5) {
                    en.hp -= b.dmg; if(en.hp <= 0) { scene.remove(en.m); ents.splice(j,1); }
                    scene.remove(b); bullets.splice(i,1); hit = true; break;
                }
            }
            if(hit) continue;
            // 打玩家
            if(b.owner !== 'player' && !pData.dead && b.position.distanceTo(camera.position) < 1.5) {
                scene.remove(b); bullets.splice(i,1);
                pData.hp -= b.dmg; if(pData.hp<0) pData.hp=0;
                // HUD 血量更新
                document.getElementById('hp-val').innerText = pData.hp; document.getElementById('hp-fill').style.width = pData.hp+"%";
                if(pData.hp<=30) document.getElementById('hp-fill').style.background = "#ff4757";
                if(pData.hp<=0) { pData.dead = true; camera.remove(wMesh); triggerEndModal(false); }
            }
        }
        if(renderer && isActive) renderer.render(scene, camera);
    }

    // 世紀會戰結束決策
    function triggerEndModal(win) {
        isActive = false; document.exitPointerLock();
        document.getElementById('game-ui').style.display = 'none';
        goScreen('scr-result');
        document.getElementById('result-title').innerText = win ? "🏆 肅清任務完成！" : "💀 指揮中心陷落！";
        document.getElementById('result-title').style.color = win ? "#eab308" : "#ff4757";
    }
</script>
</body>
